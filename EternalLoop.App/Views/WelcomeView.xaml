<UserControl x:Class="EternalLoop.App.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="34 34 52 34">
        <materialDesign:Card Style="{StaticResource EL.Card.Glass}"
                             MaxWidth="760"
                             MinHeight="380"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Padding="46">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="LOCAL AUDIO · INFINITE PLAYBACK"
                               Foreground="{StaticResource EL.Brush.Cyan}"
                               FontSize="13"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 14" />
                    <TextBlock Text="Make your music infinite"
                               Style="{StaticResource EL.Text.Display.Neon}"
                               FontSize="46"
                               TextAlignment="Center" />
                    <TextBlock Text="Drop a track, let EternalLoop find the rhythm, then listen as your song keeps evolving without reaching the end."
                               Style="{StaticResource EL.Text.Body}"
                               Foreground="{StaticResource EL.Brush.TextMuted}"
                               FontSize="16"
                               TextAlignment="Center"
                               MaxWidth="540"
                               Margin="0 20 0 34" />
                </StackPanel>

                <Border Grid.Row="1"
                        AllowDrop="True"
                        DragEnter="DropZone_DragEnter"
                        Drop="DropZone_Drop"
                        Width="520"
                        Padding="22"
                        CornerRadius="24"
                        BorderBrush="#88C88DFF"
                        BorderThickness="1.5"
                        Background="#14FFFFFF"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="MusicNotePlus"
                                                 Width="34"
                                                 Height="34"
                                                 Foreground="{StaticResource EL.Brush.Primary}"
                                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Margin="16 0" VerticalAlignment="Center">
                            <TextBlock Text="Drop your audio file here" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock Text="MP3, WAV, FLAC, M4A or AAC" Style="{StaticResource EL.Text.Caption}" Margin="0 4 0 0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Choose track"
                                Style="{StaticResource EL.Button.Primary}"
                                Command="{Binding OpenFileCommand}" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource EL.Brush.Danger}"
                           HorizontalAlignment="Center"
                           Margin="0 18 0 0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            </Grid>
        </materialDesign:Card>
    </Grid>
    </ScrollViewer>
</UserControl>
