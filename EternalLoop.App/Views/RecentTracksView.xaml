<UserControl x:Class="EternalLoop.App.Views.RecentTracksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="30">
        <materialDesign:Card Style="{StaticResource EL.Card.Glass}" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Recent tracks" Style="{StaticResource EL.Text.Display.Neon}" FontSize="38" />
                    <TextBlock Text="Open one of your last 10 tracks."
                               Style="{StaticResource EL.Text.Body}"
                               Foreground="{StaticResource EL.Brush.TextMuted}"
                               Margin="0 8 0 0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0 26 0 22"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0 0 18 0">
                        <StackPanel Visibility="{Binding HasRecentTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="14 0 14 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Track" Style="{StaticResource EL.Text.Caption}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Folder" Style="{StaticResource EL.Text.Caption}" FontWeight="SemiBold" Margin="18 0" />
                                <TextBlock Grid.Column="2" Text="Status" Style="{StaticResource EL.Text.Caption}" FontWeight="SemiBold" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding RecentTracks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="16"
                                                BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                                BorderThickness="1"
                                                Background="#12FFFFFF"
                                                Padding="14"
                                                Margin="0 0 0 10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="3*" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="90" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding FileName}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Folder}"
                                                           Foreground="{StaticResource EL.Brush.TextMuted}"
                                                           Margin="18 0"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StatusText}"
                                                           Foreground="{StaticResource EL.Brush.TextMuted}"
                                                           VerticalAlignment="Center" />

                                                <Button Grid.Column="3"
                                                        Content="Open"
                                                        Command="{Binding DataContext.OpenTrackCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource EL.Button.Primary}"
                                                        Height="34"
                                                        MinWidth="70"
                                                        Padding="12 0"
                                                        FontSize="12"
                                                        IsEnabled="{Binding Exists}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Visibility="{Binding HasRecentTracks, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                CornerRadius="24"
                                BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                BorderThickness="1"
                                Background="#12FFFFFF"
                                Padding="34">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding EmptyMessage}"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                                <Button Content="Back to home"
                                        Command="{Binding BackCommand}"
                                        Style="{StaticResource EL.Button.Primary}"
                                        Margin="0 18 0 0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Button Content="Remove missing"
                            Command="{Binding RemoveMissingCommand}"
                            Style="{StaticResource EL.Button.Secondary}"
                            HorizontalAlignment="Left" />
                    <Button Content="Back"
                            Command="{Binding BackCommand}"
                            Style="{StaticResource EL.Button.Primary}"
                            HorizontalAlignment="Right" />
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
