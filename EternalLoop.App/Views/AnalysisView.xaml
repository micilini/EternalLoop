<UserControl x:Class="EternalLoop.App.Views.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="34 34 52 34">
        <materialDesign:Card Style="{StaticResource EL.Card.Glass}"
                             Width="680"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Padding="44">
            <StackPanel HorizontalAlignment="Stretch">
                <Grid Width="128" Height="128" HorizontalAlignment="Center" Margin="0 0 0 28">
                    <Ellipse Stroke="{StaticResource EL.Brush.Primary}" StrokeThickness="9" Opacity="0.35" />
                    <Ellipse Stroke="{StaticResource EL.Brush.Cyan}" StrokeThickness="4" Opacity="0.8" Margin="18" />
                    <TextBlock Text="∞"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0 -5 0 0" />
                </Grid>

                <TextBlock Text="Preparing your infinite loop"
                           Style="{StaticResource EL.Text.Display.Neon}"
                           FontSize="34"
                           TextAlignment="Center" />
                <TextBlock Text="EternalLoop is listening to the track and building a musical map. This usually takes just a moment."
                           Style="{StaticResource EL.Text.Body}"
                           Foreground="{StaticResource EL.Brush.TextMuted}"
                           FontSize="15"
                           TextAlignment="Center"
                           MaxWidth="500"
                           HorizontalAlignment="Center"
                           Margin="0 12 0 14" />

                <TextBlock Text="{Binding AnalysisModeText}"
                           Foreground="{StaticResource EL.Brush.Cyan}"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           MaxWidth="500"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 24" />

                <ProgressBar Value="{Binding OverallProgress}"
                             Minimum="0"
                             Maximum="100"
                             Style="{StaticResource EL.ProgressBar.Brand}"
                             Height="12" />

                <TextBlock Text="{Binding FriendlyProgressText}"
                           Foreground="{StaticResource EL.Brush.TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0 14 0 22" />

                <UniformGrid Columns="6" Rows="1" Margin="0 0 0 26">
                    <Border CornerRadius="14" Padding="8" Margin="0 0 6 0" Background="#14FFFFFF">
                        <TextBlock Text="Loading" FontSize="11" TextAlignment="Center" Foreground="{StaticResource EL.Brush.TextMuted}" />
                    </Border>
                    <Border CornerRadius="14" Padding="8" Margin="0 0 6 0" Background="#14FFFFFF">
                        <TextBlock Text="Features" FontSize="11" TextAlignment="Center" Foreground="{StaticResource EL.Brush.TextMuted}" />
                    </Border>
                    <Border CornerRadius="14" Padding="8" Margin="0 0 6 0" Background="#14FFFFFF">
                        <TextBlock Text="Rhythm" FontSize="11" TextAlignment="Center" Foreground="{StaticResource EL.Brush.TextMuted}" />
                    </Border>
                    <Border CornerRadius="14" Padding="8" Margin="0 0 6 0" Background="#14FFFFFF">
                        <TextBlock Text="Local AI" FontSize="11" TextAlignment="Center" Foreground="{StaticResource EL.Brush.TextMuted}" />
                    </Border>
                    <Border CornerRadius="14" Padding="8" Margin="0 0 6 0" Background="#14FFFFFF">
                        <TextBlock Text="Loop map" FontSize="11" TextAlignment="Center" Foreground="{StaticResource EL.Brush.TextMuted}" />
                    </Border>
                    <Border CornerRadius="14" Padding="8" Background="#14FFFFFF">
                        <TextBlock Text="Ready" FontSize="11" TextAlignment="Center" Foreground="{StaticResource EL.Brush.TextMuted}" />
                    </Border>
                </UniformGrid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource EL.Brush.Danger}"
                           TextAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 18 0 0">
                    <Button Content="Back" Style="{StaticResource EL.Button.Secondary}" Command="{Binding BackCommand}" Margin="0 0 10 0" />
                    <Button Content="Cancel" Style="{StaticResource EL.Button.Primary}" Command="{Binding CancelCommand}" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
    </ScrollViewer>
</UserControl>
