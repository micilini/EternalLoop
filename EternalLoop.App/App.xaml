<Application x:Class="EternalLoop.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:EternalLoop.App.Converters"
             xmlns:views="clr-namespace:EternalLoop.App.Views"
             xmlns:viewModels="clr-namespace:EternalLoop.App.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Purple" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Color x:Key="EL.Color.Primary">#7C3AED</Color>
            <Color x:Key="EL.Color.PrimaryHover">#8B5CF6</Color>
            <Color x:Key="EL.Color.PrimaryPressed">#6D28D9</Color>
            <Color x:Key="EL.Color.Secondary">#EC4899</Color>
            <Color x:Key="EL.Color.Accent">#22D3EE</Color>
            <Color x:Key="EL.Color.Success">#10B981</Color>
            <Color x:Key="EL.Color.Warning">#F59E0B</Color>
            <Color x:Key="EL.Color.Danger">#EF4444</Color>
            <Color x:Key="EL.Color.Background0">#090711</Color>
            <Color x:Key="EL.Color.Background1">#120B24</Color>
            <Color x:Key="EL.Color.Panel">#CC1C1434</Color>
            <Color x:Key="EL.Color.PanelStrong">#EA261B48</Color>
            <Color x:Key="EL.Color.PanelBorder">#66CAA6FF</Color>
            <Color x:Key="EL.Color.TextStrong">#FFFFFFFF</Color>
            <Color x:Key="EL.Color.TextMuted">#FFBFB0DA</Color>
            <Color x:Key="EL.Color.Cyan">#FF7CE7FF</Color>
            <Color x:Key="EL.Color.Pink">#FFFF77C8</Color>
            <Color x:Key="EL.Color.Green">#FF8BFFCF</Color>
            <Color x:Key="EL.Color.Yellow">#FFFFE28A</Color>

            <SolidColorBrush x:Key="EL.Brush.Primary" Color="{StaticResource EL.Color.Primary}" />
            <SolidColorBrush x:Key="EL.Brush.PrimaryHover" Color="{StaticResource EL.Color.PrimaryHover}" />
            <SolidColorBrush x:Key="EL.Brush.PrimaryPressed" Color="{StaticResource EL.Color.PrimaryPressed}" />
            <SolidColorBrush x:Key="EL.Brush.PrimarySubtle" Color="{StaticResource EL.Color.Primary}" Opacity="0.14" />
            <SolidColorBrush x:Key="EL.Brush.Secondary" Color="{StaticResource EL.Color.Secondary}" />
            <SolidColorBrush x:Key="EL.Brush.Accent" Color="{StaticResource EL.Color.Accent}" />
            <SolidColorBrush x:Key="EL.Brush.Success" Color="{StaticResource EL.Color.Success}" />
            <SolidColorBrush x:Key="EL.Brush.Warning" Color="{StaticResource EL.Color.Warning}" />
            <SolidColorBrush x:Key="EL.Brush.Danger" Color="{StaticResource EL.Color.Danger}" />
            <SolidColorBrush x:Key="EL.Brush.AppBackground" Color="{StaticResource EL.Color.Background0}" />
            <SolidColorBrush x:Key="EL.Brush.Panel" Color="{StaticResource EL.Color.Panel}" />
            <SolidColorBrush x:Key="EL.Brush.PanelStrong" Color="{StaticResource EL.Color.PanelStrong}" />
            <SolidColorBrush x:Key="EL.Brush.PanelBorder" Color="{StaticResource EL.Color.PanelBorder}" />
            <SolidColorBrush x:Key="EL.Brush.TextStrong" Color="{StaticResource EL.Color.TextStrong}" />
            <SolidColorBrush x:Key="EL.Brush.TextMuted" Color="{StaticResource EL.Color.TextMuted}" />
            <SolidColorBrush x:Key="EL.Brush.Cyan" Color="{StaticResource EL.Color.Cyan}" />
            <SolidColorBrush x:Key="EL.Brush.Pink" Color="{StaticResource EL.Color.Pink}" />
            <SolidColorBrush x:Key="EL.Brush.Green" Color="{StaticResource EL.Color.Green}" />
            <SolidColorBrush x:Key="EL.Brush.Yellow" Color="{StaticResource EL.Color.Yellow}" />

            <LinearGradientBrush x:Key="EL.Brush.MainBackground" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#090711" Offset="0" />
                <GradientStop Color="#120B24" Offset="0.45" />
                <GradientStop Color="#0E081B" Offset="1" />
            </LinearGradientBrush>

            <FontFamily x:Key="EL.Font.Primary">Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="EL.Font.Mono">Cascadia Mono, Consolas</FontFamily>

            <Style x:Key="EL.Text.Display" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="34" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            </Style>

            <Style x:Key="EL.Text.Title" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            </Style>

            <Style x:Key="EL.Text.SectionLabel" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            </Style>

            <Style x:Key="EL.Text.Body" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="LineHeight" Value="19" />
            </Style>

            <Style x:Key="EL.Text.Caption" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="Foreground" Value="{StaticResource EL.Brush.TextMuted}" />
                <Setter Property="Opacity" Value="0.86" />
            </Style>

            <Style x:Key="EL.Text.Display.Neon" TargetType="TextBlock" BasedOn="{StaticResource EL.Text.Display}">
                <Setter Property="Foreground" Value="{StaticResource EL.Brush.TextStrong}" />
                <Setter Property="FontSize" Value="42" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>

            <Style x:Key="EL.Text.MetricValue" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="EL.Button.Base" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="42" />
                <Setter Property="MinWidth" Value="112" />
                <Setter Property="Padding" Value="18 0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.Button.Primary" TargetType="Button" BasedOn="{StaticResource EL.Button.Base}">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="{StaticResource EL.Brush.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource EL.Brush.Primary}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource EL.Brush.PrimaryHover}" />
                        <Setter Property="BorderBrush" Value="{StaticResource EL.Brush.PrimaryHover}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource EL.Brush.PrimaryPressed}" />
                        <Setter Property="BorderBrush" Value="{StaticResource EL.Brush.PrimaryPressed}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="EL.Button.Secondary" TargetType="Button" BasedOn="{StaticResource EL.Button.Base}">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{StaticResource EL.Brush.Primary}" />
            </Style>

            <Style x:Key="EL.Button.Icon" TargetType="Button">
                <Setter Property="Width" Value="42" />
                <Setter Property="Height" Value="42" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{StaticResource EL.Brush.PrimarySubtle}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.Button.IconPill" TargetType="Button">
                <Setter Property="Width" Value="46" />
                <Setter Property="Height" Value="46" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#14FFFFFF" />
                <Setter Property="BorderBrush" Value="#38CDAFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    CornerRadius="17"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#389C6CFF" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#88CDAFFF" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#557C3AED" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.Button.IconRound" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="42" />
                <Setter Property="Height" Value="42" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#14FFFFFF" />
                <Setter Property="BorderBrush" Value="#26FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    CornerRadius="16"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#337C3AED" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource EL.Brush.PanelBorder}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#557C3AED" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.Card" TargetType="materialDesign:Card">
                <Setter Property="UniformCornerRadius" Value="18" />
                <Setter Property="Padding" Value="22" />
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
            </Style>

            <Style x:Key="EL.Card.Glass" TargetType="materialDesign:Card">
                <Setter Property="UniformCornerRadius" Value="30" />
                <Setter Property="Padding" Value="24" />
                <Setter Property="Background" Value="{StaticResource EL.Brush.Panel}" />
            </Style>

            <Style x:Key="EL.Card.Strong" TargetType="materialDesign:Card" BasedOn="{StaticResource EL.Card.Glass}">
                <Setter Property="Background" Value="{StaticResource EL.Brush.PanelStrong}" />
                <Setter Property="UniformCornerRadius" Value="28" />
            </Style>

            <Style x:Key="EL.ProgressBar.Brand" TargetType="ProgressBar">
                <Setter Property="Foreground" Value="{StaticResource EL.Brush.Primary}" />
                <Setter Property="Background" Value="{StaticResource EL.Brush.PrimarySubtle}" />
                <Setter Property="Height" Value="8" />
            </Style>

            <Style x:Key="EL.Slider.Thumb" TargetType="{x:Type Thumb}">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Grid Width="18"
                                  Height="18"
                                  Background="Transparent"
                                  SnapsToDevicePixels="False"
                                  UseLayoutRounding="False">
                                <Ellipse x:Name="Dot"
                                         Width="18"
                                         Height="18"
                                         Fill="#9C6CFF"
                                         Stroke="#66FFFFFF"
                                         StrokeThickness="1"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Dot" Property="Fill" Value="#FFC88DFF" />
                                    <Setter TargetName="Dot" Property="Stroke" Value="#88FFFFFF" />
                                </Trigger>

                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="Dot" Property="Fill" Value="#FFFF77C8" />
                                    <Setter TargetName="Dot" Property="Stroke" Value="#AAFFFFFF" />
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Dot" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.Slider.Neon" TargetType="{x:Type Slider}">
                <Setter Property="Height" Value="30" />
                <Setter Property="Foreground" Value="{StaticResource EL.Brush.Primary}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Slider}">
                            <Grid MinHeight="{TemplateBinding Height}" SnapsToDevicePixels="True">
                                <Border Height="9"
                                        VerticalAlignment="Center"
                                        Background="#FF2A1D4A"
                                        BorderBrush="#553F2B6B"
                                        BorderThickness="1"
                                        CornerRadius="0" />

                                <Track x:Name="PART_Track"
                                       VerticalAlignment="Center">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      IsTabStop="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="9"
                                                            CornerRadius="0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#FF7C3AED" Offset="0" />
                                                                <GradientStop Color="#FFC88DFF" Offset="0.65" />
                                                                <GradientStop Color="#FFFF77C8" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource EL.Slider.Thumb}" />
                                    </Track.Thumb>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      IsTabStop="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="9"
                                                            CornerRadius="0"
                                                            Background="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.Slider.Position" TargetType="{x:Type Slider}" BasedOn="{StaticResource EL.Slider.Neon}">
                <Setter Property="Height" Value="30" />
            </Style>

            <Style x:Key="EL.Slider.Tuning" TargetType="{x:Type Slider}" BasedOn="{StaticResource EL.Slider.Neon}">
                <Setter Property="Height" Value="28" />
            </Style>

            <Style x:Key="EL.RadioCard.Preset" TargetType="{x:Type RadioButton}">
                <Setter Property="Height" Value="46" />
                <Setter Property="MinWidth" Value="130" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="{StaticResource EL.Font.Primary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RadioButton}">
                            <Border x:Name="Root"
                                    Height="46"
                                    CornerRadius="16"
                                    Background="#12FFFFFF"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Padding="12 0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="18" Height="18" VerticalAlignment="Center">
                                        <Ellipse x:Name="OuterCircle"
                                                 Stroke="#88CAA6FF"
                                                 StrokeThickness="1.5"
                                                 Fill="#202A1D4A" />
                                        <Ellipse x:Name="InnerCircle"
                                                 Width="8"
                                                 Height="8"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Fill="{StaticResource EL.Brush.Primary}"
                                                 Opacity="0" />
                                    </Grid>

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="10 0 0 0"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />
                                </Grid>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#1A9C6CFF" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#99CAA6FF" />
                                </Trigger>

                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#339C6CFF" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FFC88DFF" />
                                    <Setter TargetName="InnerCircle" Property="Opacity" Value="1" />
                                    <Setter TargetName="OuterCircle" Property="Stroke" Value="#FFC88DFF" />
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EL.ScrollBar.Thumb" TargetType="{x:Type Thumb}">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="MinWidth" Value="34" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border x:Name="ThumbRoot"
                                    Background="#B89C6CFF"
                                    CornerRadius="0"
                                    Opacity="0.82" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbRoot" Property="Background" Value="#D1C88DFF" />
                                    <Setter TargetName="ThumbRoot" Property="Opacity" Value="0.95" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbRoot" Property="Background" Value="#FFFF77C8" />
                                    <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Width" Value="12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Background="Transparent">
                                <Border Width="7"
                                        HorizontalAlignment="Center"
                                        Background="#30241443"
                                        CornerRadius="0"
                                        Opacity="0.92" />

                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True"
                                       Margin="0">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0" Opacity="0" IsTabStop="False" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="7" Style="{StaticResource EL.ScrollBar.Thumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0" Opacity="0" IsTabStop="False" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Width" Value="Auto" />
                                    <Setter Property="Height" Value="12" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate DataType="{x:Type viewModels:WelcomeViewModel}">
                <views:WelcomeView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:AnalysisViewModel}">
                <views:AnalysisView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:PlayerViewModel}">
                <views:PlayerView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:RecentTracksViewModel}">
                <views:RecentTracksView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
