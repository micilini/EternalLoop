<Window x:Class="EternalLoop.App.Views.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="EternalLoop"
        Height="500"
        Width="900"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="{x:Null}"
        ContentRendered="Window_ContentRendered">

    <materialDesign:Card UniformCornerRadius="30"
                         Background="#EE120B24"
                         Margin="26">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="46 42 30 42">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="56"
                           Height="56"
                           Source="/Assets/Images/eternalloop-logo.png"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True" />
                    <StackPanel Margin="18 0 0 0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="EternalLoop"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White" />

                            <Border CornerRadius="10"
                                    Padding="8 3"
                                    Margin="10 7 0 0"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding ApplicationVersion}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource EL.Brush.TextMuted}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Offline adaptive music playback"
                                   Style="{StaticResource EL.Text.Caption}"
                                   Margin="1 3 0 0" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="Building a neon map of rhythm, branches and safe looping paths."
                           Style="{StaticResource EL.Text.Body}"
                           Foreground="{StaticResource EL.Brush.TextMuted}"
                           FontSize="15"
                           Margin="0 24 40 0" />

                <StackPanel Grid.Row="3">
                    <TextBlock Text="{Binding LoadingMessage}"
                               Foreground="{StaticResource EL.Brush.TextMuted}"
                               FontSize="12"
                               Margin="0 0 0 10" />
                    <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}"
                                 IsIndeterminate="False"
                                 Width="355"
                                 HorizontalAlignment="Left"
                                 Height="10"
                                 Style="{StaticResource EL.ProgressBar.Brand}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Margin="0 28 34 28">
                <Border CornerRadius="26" Background="#141C1434" BorderBrush="#44CDAFFF" BorderThickness="1" />
                <Canvas Width="320" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="250" Height="250" Canvas.Left="35" Canvas.Top="35"
                             Stroke="{StaticResource EL.Brush.Primary}" StrokeThickness="2.4" Opacity="0.75" />
                    <Ellipse Width="176" Height="176" Canvas.Left="72" Canvas.Top="72"
                             Stroke="{StaticResource EL.Brush.Pink}" StrokeThickness="1.8" Opacity="0.48" />
                    <Ellipse Width="92" Height="92" Canvas.Left="114" Canvas.Top="114"
                             Stroke="{StaticResource EL.Brush.Cyan}" StrokeThickness="1.2" Opacity="0.45" />

                    <Line X1="160" Y1="35" X2="253" Y2="160" Stroke="{StaticResource EL.Brush.Cyan}" StrokeThickness="1.8" Opacity="0.75" />
                    <Line X1="253" Y1="160" X2="160" Y2="285" Stroke="{StaticResource EL.Brush.Pink}" StrokeThickness="1.8" Opacity="0.75" />
                    <Line X1="160" Y1="285" X2="67" Y2="160" Stroke="{StaticResource EL.Brush.Primary}" StrokeThickness="1.8" Opacity="0.75" />
                    <Line X1="67" Y1="160" X2="160" Y2="35" Stroke="{StaticResource EL.Brush.Cyan}" StrokeThickness="1.8" Opacity="0.75" />

                    <Ellipse Width="18" Height="18" Canvas.Left="151" Canvas.Top="26" Fill="{StaticResource EL.Brush.Primary}" />
                    <Ellipse Width="18" Height="18" Canvas.Left="244" Canvas.Top="151" Fill="{StaticResource EL.Brush.Cyan}" />
                    <Ellipse Width="18" Height="18" Canvas.Left="151" Canvas.Top="276" Fill="{StaticResource EL.Brush.Pink}" />
                    <Ellipse Width="18" Height="18" Canvas.Left="58" Canvas.Top="151" Fill="{StaticResource EL.Brush.Green}" />

                    <Image Canvas.Left="106"
                           Canvas.Top="106"
                           Width="108"
                           Height="108"
                           Source="/Assets/Images/eternalloop-logo.png"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True" />
                </Canvas>
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>
