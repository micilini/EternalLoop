<UserControl x:Class="EternalLoop.App.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EternalLoop.App.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="360" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0"
                             Style="{StaticResource EL.Card.Strong}"
                             Margin="0 0 14 0"
                             Padding="0">
            <Grid MinHeight="480">
                <controls:LoopMapVisualization Graph="{Binding Graph}"
                                               CurrentBeatIndex="{Binding CurrentBeatIndex}"
                                               LastJumpFromBeat="{Binding LastJumpFromBeat}"
                                               LastJumpToBeat="{Binding LastJumpToBeat}"
                                               Margin="28" />
            </Grid>
        </materialDesign:Card>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="14 0 18 0">
                <materialDesign:Card Style="{StaticResource EL.Card.Strong}" Margin="0 0 0 16" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="86"
                                Height="86"
                                CornerRadius="22"
                                ClipToBounds="True"
                                Background="#22FFFFFF">
                            <Grid>
                                <Grid Visibility="{Binding HasTrackArtwork, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <Border CornerRadius="22">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C48FF" Offset="0" />
                                                <GradientStop Color="#FF77C8" Offset="0.55" />
                                                <GradientStop Color="#7CE7FF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <materialDesign:PackIcon Kind="Music" Width="34" Height="34" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.80" />
                                </Grid>

                                <Image Source="{Binding TrackArtwork}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding HasTrackArtwork, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,86,86" RadiusX="22" RadiusY="22" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="14 0 0 0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayTrackName}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="16"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="220" />
                            <TextBlock Text="{Binding TrackDurationText, StringFormat=Total duration - {0}}"
                                       Style="{StaticResource EL.Text.Caption}"
                                       Margin="0 7 0 0" />
                            <TextBlock Text="{Binding AnalysisSourceText}"
                                       Style="{StaticResource EL.Text.Caption}"
                                       Margin="0 2 0 0" />
                            <controls:MiniSpectrumControl Height="28"
                                                          Margin="0 10 0 0"
                                                          IsPlaying="{Binding IsPlaying}"
                                                          ActivitySeed="{Binding CurrentBeatIndex}" />
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource EL.Card.Strong}" Margin="0 0 0 16" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding StopCommand}"
                                    Style="{StaticResource EL.Button.IconRound}"
                                    ToolTip="Stop">
                                <materialDesign:PackIcon Kind="Stop" Width="19" Height="19" />
                            </Button>

                            <Button Grid.Column="1"
                                    Margin="8 0 0 0"
                                    Command="{Binding PlayPauseCommand}"
                                    Style="{StaticResource EL.Button.IconRound}"
                                    ToolTip="{Binding PlayPauseText}">
                                <materialDesign:PackIcon Kind="PlayPause" Width="19" Height="19" />
                            </Button>

                            <Button Grid.Column="2"
                                    Margin="8 0 0 0"
                                    Command="{Binding BringItHomeCommand}"
                                    Style="{StaticResource EL.Button.IconRound}"
                                    ToolTip="Bring it home (deixar terminar)">
                                <materialDesign:PackIcon Kind="Flag" Width="18" Height="18" />
                            </Button>

                            <StackPanel Grid.Column="3"
                                        Margin="12 0 0 0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding PositionText}"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Position" Style="{StaticResource EL.Text.Caption}" />
                            </StackPanel>
                        </Grid>

                        <Slider Grid.Row="1"
                                x:Name="PositionSlider"
                                Margin="0 12 0 0"
                                Minimum="0"
                                Maximum="{Binding TrackDurationSeconds}"
                                Value="{Binding PositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource EL.Slider.Position}"
                                PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp" />
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource EL.Card.Strong}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Track analysis" Foreground="White" FontSize="15" FontWeight="Bold" />

                            <Button Grid.Column="1"
                                    Content="Analyze again"
                                    Command="{Binding AnalyzeAgainCommand}"
                                    Style="{StaticResource EL.Button.Secondary}"
                                    Height="32"
                                    MinWidth="0"
                                    Padding="12 0"
                                    FontSize="12" />
                        </Grid>

                        <TextBlock Text="{Binding LoopModeText, StringFormat=Mode: {0}}"
                                   Style="{StaticResource EL.Text.Caption}"
                                   Margin="0 0 0 12" />
                        <TextBlock Text="{Binding AnalyzeAgainStatusText}"
                                   Style="{StaticResource EL.Text.Caption}"
                                   Foreground="{StaticResource EL.Brush.Warning}"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 10" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Padding="14" CornerRadius="18" Margin="0 0 10 10" Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Tempo (BPM)" Style="{StaticResource EL.Text.Caption}" />
                                    <TextBlock Text="{Binding TempoText}" Style="{StaticResource EL.Text.MetricValue}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Padding="14" CornerRadius="18" Margin="0 0 0 10" Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Beat" Style="{StaticResource EL.Text.Caption}" />
                                    <TextBlock Text="{Binding CurrentBeatText}" Style="{StaticResource EL.Text.MetricValue}" FontSize="18" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Padding="14" CornerRadius="18" Margin="0 0 10 0" Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Beats" Style="{StaticResource EL.Text.Caption}" />
                                    <TextBlock Text="{Binding BeatCountText}" Style="{StaticResource EL.Text.MetricValue}" FontSize="18" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Padding="14" CornerRadius="18" Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Branches" Style="{StaticResource EL.Text.Caption}" />
                                    <TextBlock Text="{Binding BranchCountText}" Style="{StaticResource EL.Text.MetricValue}" FontSize="18" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
