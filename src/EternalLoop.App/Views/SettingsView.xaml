<UserControl x:Class="EternalLoop.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="34">
        <materialDesign:Card Style="{StaticResource EL.Card.Glass}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Settings"
                                   Style="{StaticResource EL.Text.Display.Neon}"
                                   FontSize="38" />

                        <Border CornerRadius="12"
                                Padding="10 4"
                                Margin="14 8 0 0"
                                BorderThickness="1">
                            <TextBlock Text="{Binding ApplicationVersion}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource EL.Brush.TextMuted}" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Your preferences are saved locally on this device."
                               Style="{StaticResource EL.Text.Body}"
                               Foreground="{StaticResource EL.Brush.TextMuted}"
                               Margin="0 8 0 0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0 28 0 24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0 0 18 0">
                        <TextBlock Text="Loop tuning" Style="{StaticResource EL.Text.SectionLabel}" Foreground="White" />
                        <TextBlock Text="Choose how strict or playful EternalLoop should be. Apply changes without restarting playback."
                                   Style="{StaticResource EL.Text.Body}" Foreground="{StaticResource EL.Brush.TextMuted}" Margin="0 4 0 12" />

                        <Border CornerRadius="18"
                                Padding="16"
                                BorderThickness="1"
                                BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                Background="#16FFFFFF">
                            <StackPanel>
                                <TextBlock Text="Preset" Style="{StaticResource EL.Text.Caption}" Foreground="{StaticResource EL.Brush.TextMuted}" />
                                <UniformGrid Columns="3" Margin="0 10 0 10">
                                    <RadioButton Content="Conservative"
                                                 GroupName="TuningPresetGroup"
                                                 IsChecked="{Binding IsConservativePresetSelected, Mode=TwoWay}"
                                                 Style="{StaticResource EL.RadioCard.Preset}"
                                                 Margin="0 0 8 0" />

                                    <RadioButton Content="Balanced"
                                                 GroupName="TuningPresetGroup"
                                                 IsChecked="{Binding IsBalancedPresetSelected, Mode=TwoWay}"
                                                 Style="{StaticResource EL.RadioCard.Preset}"
                                                 Margin="4 0" />

                                    <RadioButton Content="Wild"
                                                 GroupName="TuningPresetGroup"
                                                 IsChecked="{Binding IsWildPresetSelected, Mode=TwoWay}"
                                                 Style="{StaticResource EL.RadioCard.Preset}"
                                                 Margin="8 0 0 0" />
                                </UniformGrid>

                                <TextBlock Text="{Binding PresetDescription}"
                                           Style="{StaticResource EL.Text.Body}"
                                           Foreground="{StaticResource EL.Brush.TextMuted}"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="{Binding TuningGraphSummaryText}"
                                           Style="{StaticResource EL.Text.Caption}"
                                           Margin="0 10 0 0" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Margin="0 14 0 0">
                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Similarity threshold" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SimilarityThreshold, StringFormat={}{0:0.00}}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="0.65" Maximum="0.95" TickFrequency="0.01" Value="{Binding SimilarityThreshold, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="Higher = safer, fewer branches. Lower = more permissive." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Lookahead depth" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LookaheadDepth}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding LookaheadDepth, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="How many future beats must also match." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Minimum jump distance" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MinJumpDistance}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="4" Maximum="64" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MinJumpDistance, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="Avoids tiny jumps that sound like stutter." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Max branches per beat" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MaxBranchesPerBeat}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="1" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaxBranchesPerBeat, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="Limits how dense the loop map can become." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Jump probability" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding JumpProbability, StringFormat={}{0:P0}}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="0" Maximum="1" TickFrequency="0.05" Value="{Binding JumpProbability, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="How strongly EternalLoop accepts a safe branch once the chance ramp allows it." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="Jump cooldown" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding JumpCooldown}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="0" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding JumpCooldown, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="Minimum beats between two jumps." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Width="280" CornerRadius="18" Padding="14" Margin="0 0 12 12"
                                    BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                    BorderThickness="1"
                                    Background="#10FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="First pass length" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding FirstPassLinearPlaybackRatio, StringFormat={}{0:P0}}" Style="{StaticResource EL.Text.Caption}" />
                                    <Slider Minimum="0" Maximum="0.90" TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding FirstPassLinearPlaybackRatio, Mode=TwoWay}" Style="{StaticResource EL.Slider.Tuning}" />
                                    <TextBlock Text="0% = jumps may start immediately; higher values preserve more of the first linear pass." Style="{StaticResource EL.Text.Caption}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Height="1" Background="{StaticResource EL.Brush.PanelBorder}" Opacity="0.45" Margin="0 24" />

                        <TextBlock Text="Analysis cache" Style="{StaticResource EL.Text.SectionLabel}" Foreground="White" />
                        <TextBlock Text="Saved analyses make repeated tracks open much faster. Audio files are never copied into the cache."
                                   Style="{StaticResource EL.Text.Body}" Foreground="{StaticResource EL.Brush.TextMuted}" Margin="0 4 0 12" />

                        <Border CornerRadius="18"
                                Padding="16"
                                BorderThickness="1"
                                BorderBrush="{StaticResource EL.Brush.PanelBorder}"
                                Background="#16FFFFFF">
                            <StackPanel>
                                <TextBlock Text="{Binding CacheSummaryText}"
                                           Style="{StaticResource EL.Text.MetricValue}"
                                           FontSize="18" />
                                <TextBlock Text="{Binding CachePathText}"
                                           Style="{StaticResource EL.Text.Caption}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0 6 0 14" />

                                <WrapPanel>
                                    <Button Content="Refresh"
                                            Command="{Binding RefreshCacheStatsCommand}"
                                            Style="{StaticResource EL.Button.Secondary}"
                                            Margin="0 0 10 0" />
                                    <Button Content="Open folder"
                                            Command="{Binding OpenCacheFolderCommand}"
                                            Style="{StaticResource EL.Button.Secondary}"
                                            Margin="0 0 10 0" />
                                    <Button Content="Clear cache"
                                            Command="{Binding ClearCacheCommand}"
                                            Style="{StaticResource EL.Button.Primary}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Reset Balanced"
                            Command="{Binding ResetBalancedCommand}"
                            Style="{StaticResource EL.Button.Secondary}" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding TuningStatusText}"
                               Style="{StaticResource EL.Text.Caption}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="14 0" />

                    <Button Grid.Column="2"
                            Content="Back"
                            Style="{StaticResource EL.Button.Primary}"
                            Command="{Binding BackCommand}" />
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
